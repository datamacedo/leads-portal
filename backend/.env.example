# Copie para .env e preencha
ENV=dev
DATABASE_URL=sqlite:///./inforge_dev.db
# Produção (Railway injeta automaticamente): postgresql://user:pass@host:5432/db
SECRET_KEY=gere-com-openssl-rand-hex-32

# Meta Lead Ads
META_VERIFY_TOKEN=inforge-meta-verify
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=

# Enriquecimento: mock | speedio | econodata
ENRICHMENT_PROVIDER=mock
SPEEDIO_API_KEY=
ECONODATA_API_KEY=

CORS_ORIGINS=*
